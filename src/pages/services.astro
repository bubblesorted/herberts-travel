---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Services | Herberts Travel" description="School transport, private coach hire, and group day trips across Bedfordshire, Hertfordshire and Cambridgeshire.">
  <!-- Hero -->
  <section class="bg-navy-dark text-white py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-4xl sm:text-5xl font-bold">Our Services</h1>
      <p class="mt-4 text-white/70 text-lg max-w-2xl">Whatever your transport needs, we have the experience and vehicles to get you there safely and comfortably.</p>
    </div>
  </section>

  <!-- School Contracts -->
  <section id="schools" class="py-16 sm:py-20 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-navy/10 text-navy px-3 py-1 rounded-full text-sm font-medium mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            School Transport
          </div>
          <h2 class="font-heading text-3xl font-bold text-navy-dark">School Contracts</h2>
          <p class="mt-4 text-gray-600 leading-relaxed">
            We provide daily school transport services with the reliability and safety standards that parents and schools demand. Our drivers are fully DBS-checked and trained to work with children.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              DBS-checked, professional drivers
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Reliable daily routes with punctual timekeeping
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Vehicles equipped with CCTV and seatbelts
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Flexible contract terms to suit your school calendar
            </li>
          </ul>
        </div>
        <div class="bg-navy/5 rounded-2xl p-8 text-center">
          <img src="/images/enhanced/school-community.jpg" alt="Herberts Travel school bus by village church" class="rounded-lg shadow-md w-full h-64 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Private Hire -->
  <section id="corporate" class="py-16 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1 bg-navy/5 rounded-2xl p-8 text-center">
          <img src="/images/enhanced/fleet-modern.jpg" alt="Herberts Travel modern coach fleet" class="rounded-lg shadow-md w-full h-64 object-cover" />
        </div>
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 bg-navy/10 text-navy px-3 py-1 rounded-full text-sm font-medium mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            Private Hire
          </div>
          <h2 class="font-heading text-3xl font-bold text-navy-dark">Private Hire</h2>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Weddings, parties, corporate events, airport transfers — whatever the occasion, we'll get your group there comfortably and on time. You organise the event, we'll handle the transport.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Weddings, birthdays, and special occasions
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Corporate events and team away days
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Airport transfers and multi-stop routes
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Flexible scheduling to suit your plans
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Day Trips -->
  <section id="daytrips" class="py-16 sm:py-20 bg-cream">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-navy/10 text-navy px-3 py-1 rounded-full text-sm font-medium mb-4">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Day Trips
          </div>
          <h2 class="font-heading text-3xl font-bold text-navy-dark">Day Trips & Excursions</h2>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Whether it's a trip to the seaside, a city break, or a countryside tour, we make group travel easy and enjoyable. Sit back, relax, and let us handle the driving.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Community groups and social clubs
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Sporting events and race days
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Coastal and countryside destinations
            </li>
            <li class="flex items-start gap-3 text-gray-700">
              <svg class="w-5 h-5 text-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              Theatre trips and city sightseeing
            </li>
          </ul>
        </div>
        <div class="bg-navy/5 rounded-2xl p-8 text-center">
          <img src="/images/enhanced/scenic-road.jpg" alt="Herberts Travel coach on countryside road" class="rounded-lg shadow-md w-full h-64 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-bold text-white">Need something bespoke?</h2>
      <p class="mt-4 text-white/70 text-lg">We're flexible. Tell us what you need and we'll put together a tailored transport solution.</p>
      <a href="/contact" class="inline-flex items-center justify-center mt-8 px-8 py-3 bg-gold hover:bg-gold-dark text-white font-medium rounded-lg transition-colors text-lg">
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
