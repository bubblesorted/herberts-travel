---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Message Sent | Herberts Travel">
  <section class="bg-cream min-h-[60vh] flex items-center">
    <div class="max-w-lg mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-green-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="font-heading text-3xl sm:text-4xl text-navy-dark">Thanks for getting in touch</h1>
      <p class="mt-4 text-gray-600 leading-relaxed">We've got your message and will get back to you as soon as we can — usually within a few hours during business hours.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center px-6 py-3 bg-navy hover:bg-navy-dark text-white font-medium rounded-lg transition-colors">
          Back to Home
        </a>
        <a href="https://wa.me/44XXXXXXXXXX?text=Hi%2C%20I%27ve%20just%20sent%20a%20quote%20request" target="_blank" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-green-500 hover:bg-green-600 text-white font-medium rounded-lg transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.121.553 4.114 1.519 5.845L.525 23.5l5.791-.984A11.946 11.946 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-1.875 0-3.628-.523-5.127-1.428l-.358-.213-3.71.973.99-3.618-.233-.371A9.723 9.723 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/></svg>
          Need a faster reply? WhatsApp us
        </a>
      </div>
    </div>
  </section>
</Layout>
