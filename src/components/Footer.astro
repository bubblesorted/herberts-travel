---
const year = new Date().getFullYear();
---
<footer class="bg-navy-dark text-white/70">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Company -->
      <div>
        <img src="/images/logo.png" alt="Herberts Travel" class="h-10 w-auto mb-4" />
        <p class="text-sm leading-relaxed">
          Family-run coach and bus hire serving Bedfordshire, Hertfordshire and Cambridgeshire since 1990. We know these roads like the back of our hand.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-gold font-heading text-lg mb-4">Quick Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/services" class="hover:text-gold-light transition-colors">Services</a></li>
          <li><a href="/fleet" class="hover:text-gold-light transition-colors">Our Fleet</a></li>
          <li><a href="/about" class="hover:text-gold-light transition-colors">About Us</a></li>
          <li><a href="/contact" class="hover:text-gold-light transition-colors">Get in Touch</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-gold font-heading text-lg mb-4">Get in Touch</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="mailto:booking@herberts-travel.co.uk" class="hover:text-gold-light transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              booking@herberts-travel.co.uk
            </a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>Barford Road, Blunham<br />Bedford, MK44 3NA</span>
          </li>
          <li>
            <a href="/contact" class="hover:text-gold-light transition-colors flex items-center gap-2">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
              Request a quote
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-8 pt-8 text-center text-xs text-white/40">
      &copy; {year} Herberts Travel. All rights reserved.
    </div>
  </div>
</footer>
